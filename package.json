  "bugs": {
    "url": "https://github.com/mhmdtshref/portfolio/issues"
  },
  "homepage": "https://github.com/mhmdtshref/portfolio#readme",
  "dependencies": {
    "env2": "^2.2.2",
    "express": "^4.17.1",
    "express-history-api-fallback": "^2.2.1",
    "mongoose": "^5.5.14",
    "nodemailer": "^6.2.1"
  },
  "devDependencies": {
    "codecov": "^3.5.0",
    "eslint": "^5.16.0",
    "eslint-config-airbnb-base": "^13.1.0",
    "eslint-plugin-import": "^2.17.3",
