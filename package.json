{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Create your own portfolio - server side.",
  "main": "index.js",
  "scripts": {
    "test": "jest ./tests",
    "start": "node ./src/server.js",
    "dev:client": "cd client && npm run start",
    "dev:admin": "cd admin && npm run start",
    "dev:server": "nodemon ./src/server.js",
    "eslint": "eslint ./src",
    "eslint:fix": "eslint --fix ./src",
    "coverage": "jest --coverage ./tests",
    "heroku-postbuild": "cd client && npm i && npm run build && cd .. && cd admin && npm i && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhmdtshref/portfolio.git"
  },
  "keywords": [
    "portfolio",
    "profile",
    "services",
    "CV",
    "Resume"
  ],
